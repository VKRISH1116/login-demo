# Copy this file to ".env" and fill in real values.
# ".env" is gitignored and must NEVER be committed.

# ── Database ──
# Password for the Postgres user (must match docker-compose / your DB).
DB_PASSWORD=change_me
# Optional overrides (defaults work for the local docker-compose setup):
# DB_URL=jdbc:postgresql://localhost:5433/login_demo
# DB_USERNAME=login

# ── JWT ──
# Signing secret for JSON Web Tokens. Use a long random string (>= 64 chars).
# Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_characters_long
# Optional: token lifetime in ms (default 900000 = 15 min).
# JWT_EXPIRATION_MS=900000
